# ============================================================
# Lyrica API — Environment Variables (Public Repo Version)
# ============================================================
# Copy this file to '.env' and fill in your details.
# Do NOT commit '.env' or any files containing credentials.
# ============================================================

# Secure admin key to protect administrative endpoints.
# Required for proxy rotation and config hot-reload endpoints.
ADMIN_KEY=your_secure_admin_key_here

# ── API Tokens (Optional) ────────────────────────────────────
# Genius API token — gets plain text lyrics (source 1)
# Register at: https://genius.com/api-clients
GENIUS_TOKEN=

# Musixmatch token — gets synced LRC lyrics (source 6)
# Register at: https://developer.musixmatch.com/
MUSIXMATCH_TOKEN=

# ── Rate Limiting ────────────────────────────────────────────
# Storage URI for Flask-Limiter. Use Redis (e.g. redis://host:6379)
# for multi-worker production environments, or memory:// for local dev.
RATE_LIMIT_STORAGE_URI=memory://

# ── Caching & Logs ───────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Cache TTL (time-to-live) in seconds
CACHE_TTL=86400

# Directory where cache JSON files are stored
CACHE_DIR=cache_data
